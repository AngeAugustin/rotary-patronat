generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  ADMIN
  PRESIDENT
  SECRETARY
  TREASURER
  COMMISSION_LEAD
  MEMBER
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  SUSPENDED
  COMPLETED
}

enum ProjectTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum PostKind {
  MEMBER_POST
  ANNOUNCEMENT
  EVENT
  COMMUNIQUE
}

enum PostVisibility {
  ALL_MEMBERS
  COMMISSION
}

enum ConversationType {
  DIRECT
  GROUP
}

enum NotificationType {
  NEW_MESSAGE
  NEW_POST
  POST_COMMENT
  POST_LIKE
  POST_MENTION
  VOLUNTEERING_VALIDATED
  VOLUNTEERING_REJECTED
  CALENDAR_INVITE
  SYSTEM
}

enum VolunteeringStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum CalendarEventType {
  MEETING
  EVENT
  COMMISSION
  PROJECT
  OTHER
}

enum CalendarEventFormat {
  IN_PERSON
  ONLINE
}

enum CalendarEventVisibility {
  PRIVATE
  PUBLIC
}

enum AttendanceStatus {
  INVITED
  ACCEPTED
  DECLINED
  MAYBE
}

enum DocumentVisibility {
  PUBLIC
  PRIVATE
}

enum DocumentFileType {
  PDF
  IMAGE
  VIDEO
  OTHER
}

enum MembershipApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

model User {
  id               String             @id @default(uuid())
  email            String             @unique
  passwordHash     String
  firstName        String
  lastName         String
  isActive         Boolean            @default(true)
  roles            UserRole[]
  refreshTokens    RefreshToken[]
  commissions      CommissionMember[]
  member           Member?
  ledCommissions   Commission[]       @relation("CommissionLead")
  ledProjects      Project[]          @relation("ProjectLead")
  projectMembers   ProjectMember[]
  assignedTasks    ProjectTask[]      @relation("TaskAssignee")
  projectHistory   ProjectHistory[]
  activityLogs     ActivityLog[]
  posts            Post[]
  postLikes        PostLike[]
  postComments     PostComment[]
  createdConversations Conversation[] @relation("ConversationCreator")
  conversationMemberships ConversationMember[]
  sentMessages     Message[]
  notifications    Notification[]
  volunteeringDeclarations VolunteeringDeclaration[]
  validatedVolunteering VolunteeringDeclaration[] @relation("VolunteeringValidator")
  createdCalendarEvents CalendarEvent[]
  calendarAttendances CalendarEventAttendee[]
  uploadedDocuments Document[]
  reviewedMembershipApplications MembershipApplication[] @relation("MembershipReviewer")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@map("users")
}

model Role {
  id        String     @id @default(uuid())
  code      RoleCode   @unique
  label     String
  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  resource   String?
  resourceId String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("activity_logs")
}

model NewsCategory {
  id        String        @id @default(uuid())
  name      String
  slug      String        @unique
  articles  NewsArticle[]

  @@map("news_categories")
}

model NewsArticle {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  excerpt     String
  content     String        @db.Text
  coverImage  String?
  categoryId  String
  category    NewsCategory  @relation(fields: [categoryId], references: [id])
  status      PublishStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
  @@map("news_articles")
}

model Action {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  description String        @db.Text
  summary     String?
  date        DateTime
  location    String
  coverImage  String?
  gallery     Json?
  videos      Json?
  partners    Json?
  results     String?       @db.Text
  featured    Boolean       @default(false)
  status      PublishStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([featured])
  @@map("actions")
}

model Meeting {
  id              String         @id @default(uuid())
  title           String
  slug            String         @unique
  description     String?        @db.Text
  date            DateTime
  startTime       String
  location        String
  agenda          String?        @db.Text
  speakers        Json?
  status          PublishStatus  @default(DRAFT)
  publishedAt     DateTime?
  calendarEventId String?        @unique
  calendarEvent   CalendarEvent? @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status, date])
  @@map("meetings")
}

model ClubProfile {
  id               String   @id @default("club-profile")
  history          String   @db.Text
  vision           String   @db.Text
  mission          String   @db.Text
  values           Json
  organization     String   @db.Text
  presidentMessage String   @db.Text
  presidentName    String
  presidentTitle   String
  presidentPhoto   String?
  updatedAt        DateTime @updatedAt

  @@map("club_profile")
}

model ExecutiveMember {
  id        String @id @default(uuid())
  name      String
  role      String
  photo     String?
  bio       String?
  sortOrder Int    @default(0)

  @@map("executive_members")
}

model Commission {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  description String             @db.Text
  sortOrder   Int                @default(0)
  leadUserId  String?
  leadUser    User?              @relation("CommissionLead", fields: [leadUserId], references: [id], onDelete: SetNull)
  members     CommissionMember[]
  projects    Project[]
  posts       Post[]
  calendarEvents CalendarEvent[]
  documents      Document[]

  @@map("commissions")
}

model CommissionMember {
  userId       String
  commissionId String
  role         String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  commission   Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)

  @@id([userId, commissionId])
  @@map("commission_members")
}

model Project {
  id              String          @id @default(uuid())
  title           String
  slug            String          @unique
  description     String          @db.Text
  objectives      String?         @db.Text
  commissionId    String
  commission      Commission      @relation(fields: [commissionId], references: [id])
  leadUserId      String
  leadUser        User            @relation("ProjectLead", fields: [leadUserId], references: [id])
  status          ProjectStatus   @default(PLANNED)
  progressPercent Int             @default(0)
  startDate       DateTime
  endDate         DateTime?
  budgetPlanned   Decimal         @db.Decimal(12, 2)
  budgetSpent     Decimal         @default(0) @db.Decimal(12, 2)
  partners        Json?
  beneficiaries   Json?
  members         ProjectMember[]
  tasks           ProjectTask[]
  history         ProjectHistory[]
  calendarEvents  CalendarEvent[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([commissionId])
  @@index([status])
  @@index([leadUserId])
  @@map("projects")
}

model ProjectMember {
  projectId String
  userId    String
  role      String?
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_members")
}

model ProjectTask {
  id          String            @id @default(uuid())
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  assigneeId  String?
  assignee    User?             @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  status      ProjectTaskStatus @default(TODO)
  dueDate     DateTime?
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([projectId])
  @@index([assigneeId])
  @@map("project_tasks")
}

model ProjectHistory {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  changes   Json?
  createdAt DateTime @default(now())

  @@index([projectId])
  @@map("project_history")
}

model GalleryImage {
  id        String @id @default(uuid())
  url       String
  caption   String?
  sortOrder Int    @default(0)

  @@map("gallery_images")
}

model ClubTimelineEvent {
  id          String  @id @default(uuid())
  year        Int
  title       String
  description String  @db.Text
  imageUrl    String?
  highlight   Boolean @default(false)
  sortOrder   Int     @default(0)

  @@index([sortOrder])
  @@map("club_timeline_events")
}

model SocialLink {
  id        String @id @default(uuid())
  platform  String
  url       String
  sortOrder Int    @default(0)

  @@map("social_links")
}

model Post {
  id           String         @id @default(uuid())
  authorId     String
  author       User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  kind         PostKind       @default(MEMBER_POST)
  content      String         @db.Text
  attachments  Json?
  linkUrl      String?
  visibility   PostVisibility @default(ALL_MEMBERS)
  commissionId String?
  commission   Commission?    @relation(fields: [commissionId], references: [id], onDelete: SetNull)
  repostOfId   String?
  repostOf     Post?          @relation("Reposts", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts      Post[]         @relation("Reposts")
  likes        PostLike[]
  comments     PostComment[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([kind, createdAt])
  @@index([authorId])
  @@index([commissionId])
  @@map("posts")
}

model PostLike {
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([postId, userId])
  @@map("post_likes")
}

model PostComment {
  id        String        @id @default(uuid())
  postId    String
  authorId  String
  parentId  String?
  content   String        @db.Text
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    PostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   PostComment[] @relation("CommentReplies")
  createdAt DateTime      @default(now())

  @@index([postId])
  @@map("post_comments")
}

model Conversation {
  id          String               @id @default(uuid())
  type        ConversationType
  name        String?
  createdById String
  createdBy   User                 @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members     ConversationMember[]
  messages    Message[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([updatedAt])
  @@map("conversations")
}

model ConversationMember {
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
  @@map("conversation_members")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String       @db.Text
  attachments    Json?
  deliveredAt    DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  type       NotificationType
  title      String
  body       String?
  resource   String?
  resourceId String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model VolunteeringDeclaration {
  id              String             @id @default(uuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  visitedClub     String
  city            String
  country         String
  activity        String
  description     String             @db.Text
  date            DateTime
  startTime       String
  durationMinutes Int
  hours           Decimal            @db.Decimal(5, 2)
  proofUrl        String?
  status          VolunteeringStatus @default(PENDING)
  validatedById   String?
  validatedBy     User?              @relation("VolunteeringValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  validatedAt     DateTime?
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId])
  @@index([status])
  @@index([date])
  @@map("volunteering_declarations")
}

model CalendarEvent {
  id            String                   @id @default(uuid())
  title         String
  description   String?                  @db.Text
  type          CalendarEventType        @default(EVENT)
  format        CalendarEventFormat      @default(IN_PERSON)
  visibility    CalendarEventVisibility  @default(PRIVATE)
  startAt       DateTime
  endAt         DateTime
  location      String?
  meetingUrl    String?
  commissionId  String?
  commission    Commission?              @relation(fields: [commissionId], references: [id], onDelete: SetNull)
  projectId     String?
  project       Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdById   String
  createdBy     User                     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  attendees     CalendarEventAttendee[]
  publicMeeting Meeting?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([startAt, endAt])
  @@index([commissionId])
  @@index([visibility])
  @@map("calendar_events")
}

model CalendarEventAttendee {
  eventId  String
  userId   String
  status   AttendanceStatus @default(INVITED)
  event    CalendarEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@index([userId])
  @@map("calendar_event_attendees")
}

model DocumentCategory {
  id         String             @id @default(uuid())
  name       String
  slug       String             @unique
  visibility DocumentVisibility @default(PRIVATE)
  sortOrder  Int                @default(0)
  documents  Document[]

  @@map("document_categories")
}

model Document {
  id           String             @id @default(uuid())
  title        String
  slug         String             @unique
  description  String?
  fileUrl      String
  fileType     DocumentFileType   @default(PDF)
  mimeType     String?
  fileSize     Int?
  visibility   DocumentVisibility @default(PRIVATE)
  categoryId   String
  category     DocumentCategory   @relation(fields: [categoryId], references: [id])
  commissionId String?
  commission   Commission?        @relation(fields: [commissionId], references: [id], onDelete: SetNull)
  uploadedById String
  uploadedBy   User               @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  downloadCount Int               @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([visibility, categoryId])
  @@index([uploadedById])
  @@map("documents")
}

model MembershipApplication {
  id             String                      @id @default(uuid())
  firstName      String
  lastName       String
  email          String
  phone          String
  profession     String
  sponsorFirstName String?
  sponsorLastName  String?
  motivation     String                      @db.Text
  attachmentUrls Json?
  status         MembershipApplicationStatus @default(PENDING)
  adminNotes     String?                     @db.Text
  reviewedById   String?
  reviewedBy     User?                       @relation("MembershipReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  member         Member?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@index([status, createdAt])
  @@map("membership_applications")
}

model Member {
  id                      String                 @id @default(uuid())
  firstName               String
  lastName                String
  email                   String                 @unique
  phone                   String?
  profession              String?
  sponsorFirstName        String?
  sponsorLastName         String?
  motivation              String?                @db.Text
  status                  MemberStatus           @default(ACTIVE)
  joinedAt                DateTime               @default(now())
  membershipApplicationId String?                @unique
  membershipApplication   MembershipApplication? @relation(fields: [membershipApplicationId], references: [id], onDelete: SetNull)
  userId                  String?                @unique
  user                    User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  @@index([status, joinedAt])
  @@map("members")
}
